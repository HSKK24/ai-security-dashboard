# NVD API key (optional but recommended; raises rate limits)
# https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# Gemini API key (required for the LLM summarization step)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# GitHub token (only needed when llm.provider is "github")
GITHUB_TOKEN=
